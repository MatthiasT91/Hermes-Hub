# Hermes Distributed Network - Production Configuration
# Copy this to .env and fill in your actual values

# ==================== Server Configuration ====================
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# ==================== JWT & Authentication ====================
# JWT_SECRET must match across all files (server.js, middleware/auth.js, routes/user-auth.js)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin Authentication Token (for admin endpoints)
HERMES_AUTH_TOKEN=your-admin-token-here

# ==================== Network & Domains ====================
# Your public domain where the Hermes Hub will be accessible
NETWORK_DOMAIN=https://your-hermes-network.com

# Cloudflare Tunnel Configuration
# Set to true if using Cloudflare Tunnel (recommended for production)
CLOUDFLARE_TUNNEL_ENABLED=true
CLOUDFLARE_TUNNEL_URL=https://hermes.your-subdomain.com

# Cloudflare Tunnel Token (from cf tunnel login command)
# Run: cf tunnel login and cf tunnel create to get the token
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# Alternative: If not using Cloudflare Tunnel, set to false
# CLOUDFLARE_TUNNEL_ENABLED=false

# ==================== Security & API Keys ====================
# Enable remote API verification (requires REMOTE_API_URL to be set)
VERIFY_API_KEYS=true
REMOTE_API_URL=https://api.your-server.com/verify

# Optional: External verification service
EXTERNAL_VERIFICATION_URL=https://external-verify.service.com

# ==================== Analytics & Monitoring ====================
LOG_ANALYTICS=true
ANALYTICS_URL=https://analytics.your-server.com/log

# ==================== Data Storage ====================
USER_PROFILES_PATH=./data/user_profiles.json
NETWORK_STATE_PATH=./data/network_state.json
DATA_DIR=./data

# ==================== Rate Limiting (Optional) ====================
MAX_REQUESTS_PER_MINUTE=100
MAX_CONNECTIONS=500

# ==================== WebSocket Configuration ====================
WEBSOCKET_HEARTBEAT_INTERVAL=25000
WEBSOCKET_TIMEOUT=60000

# ==================== Production Notes ====================
# 1. Set JWT_SECRET to a random 32+ character string
# 2. Set CLOUDFLARE_TUNNEL_TOKEN after running: cf tunnel login
# 3. Update NETWORK_DOMAIN to your actual public URL
# 4. Ensure NODE_ENV=production for logging optimization
# 5. Consider adding HTTPS redirect rules in Cloudflare if using tunnel